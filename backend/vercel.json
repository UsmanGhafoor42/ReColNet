{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "DATABASE_URL": "sqlite+aiosqlite:////tmp/recolnet.db",
    "UPLOAD_DIR": "/tmp/uploads"
  }
}

