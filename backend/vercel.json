{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "app/**"
        ],
        "excludeFiles": "{.venv/**,uploads/**,models/**,recolnet.db}"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "DATABASE_URL": "sqlite+aiosqlite:////tmp/recolnet.db",
    "UPLOAD_DIR": "/tmp/uploads",
    "MODELS_DIR": "/tmp/models"
  }
}

