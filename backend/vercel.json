{
  "version": 2,
  "installCommand": "pip install -r requirements.txt && python -c \"from app.services.model_download import download_models; download_models()\"",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "app/**",
          "models/**"
        ],
        "excludeFiles": "{.venv/**,uploads/**,recolnet.db}"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "DATABASE_URL": "sqlite+aiosqlite:////tmp/recolnet.db",
    "UPLOAD_DIR": "/tmp/uploads"
  }
}
